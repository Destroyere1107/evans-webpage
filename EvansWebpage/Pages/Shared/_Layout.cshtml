<!-- Theme Selector Dialog -->
<script>
    (function () {
        // Available themes - Paste new ones here
        const themes = [
            {id: 'dark', label: 'Simple Dark'},
            {id: 'light', label: 'Simple Light'},
            {id: 'blue', label: 'Blue'},
            {id: 'fancy', label: 'Fancy'},
            {id: 'cool', label: 'Cool'},
            {id: 'gradient', label: 'Gradient'},
            {id: 'aero', label: 'Aero'},
            {id: 'bling', label: 'Bling (WIP)'}
        ];

        // Get current theme from localStorage, default to 'gradient'
        let currentThemeId = localStorage.getItem('theme') || 'gradient';
        if (!themes.some(t => t.id === currentThemeId)) {
            currentThemeId = 'gradient';
        }

        // Main button that opens the dialog
        const toggleBtn = document.createElement('button');
        toggleBtn.id = 'theme-toggle';
        toggleBtn.textContent = '[ Themes ]';
        document.body.appendChild(toggleBtn);

        // Create the dialog element
        const dialog = document.createElement('dialog');
        dialog.id = 'theme-dialog';

        const dialogTitle = document.createElement('h3');
        dialogTitle.textContent = 'Select a Theme';
        dialogTitle.style.marginTop = '0';
        dialogTitle.style.color = 'var(--accent-blue)';
        dialog.appendChild(dialogTitle);

        // Create a button for each theme
        themes.forEach(theme => {
            const themeBtn = document.createElement('button');
            themeBtn.className = 'theme-select-btn';
            themeBtn.textContent = theme.label;

            // Highlight the currently active theme
            if (theme.id === currentThemeId) {
                themeBtn.classList.add('active');
            }

            themeBtn.onclick = function () {
                // Remove existing theme classes from HTML tag
                themes.forEach(t => {
                    if (t.id !== 'dark') {
                        document.documentElement.classList.remove(t.id + '-mode');
                    }
                });

                // Add new theme class (if not default dark)
                if (theme.id !== 'dark') {
                    document.documentElement.classList.add(theme.id + '-mode');
                }

                // Save preference
                localStorage.setItem('theme', theme.id);
                currentThemeId = theme.id;

                // Update active styling in the dialog
                dialog.querySelectorAll('.theme-select-btn').forEach(b => b.classList.remove('active'));
                themeBtn.classList.add('active');
            };

            dialog.appendChild(themeBtn);
        });

        // Close button
        const closeBtn = document.createElement('button');
        closeBtn.textContent = 'Close';
        closeBtn.className = 'theme-dialog-close';
        closeBtn.onclick = () => dialog.close();

        const closeContainer = document.createElement('div');
        closeContainer.style.marginTop = '15px';
        closeContainer.style.textAlign = 'right';
        closeContainer.appendChild(closeBtn);
        dialog.appendChild(closeContainer);

        // Add this dialog to the page
        document.body.appendChild(dialog);

        toggleBtn.onclick = function () {
            dialog.showModal();
        };

        // Close dialog when clicking outside of it
        dialog.addEventListener('click', function (event) {
            if (event.target === dialog) {
                dialog.close();
            }
        });
    })();
</script>

</body>
