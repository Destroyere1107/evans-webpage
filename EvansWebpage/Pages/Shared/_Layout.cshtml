        // Apply theme immediately (checks URL parameters first, then localStorage)
        (function () {
            // Add new themes here as well...
            const themes = ['dark', 'light', 'blue', 'fancy', 'cool', 'gradient', 'bling', 'aero'];
            const urlParams = new URLSearchParams(window.location.search);
            const urlTheme = urlParams.get('theme');

            let saved = localStorage.getItem('theme') || 'gradient';

            if (urlTheme && themes.includes(urlTheme)) {
                saved = urlTheme;
                localStorage.setItem('theme', urlTheme);
            }

            if (saved !== 'dark') {
                document.documentElement.className = saved + '-mode';
            }
        })();
        <link rel="alternate" type="application/rss+xml" title="Destroyere1107's Happenings" href="/rss.xml" />
        
    </script>
