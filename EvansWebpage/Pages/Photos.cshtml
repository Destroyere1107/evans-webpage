        </div>
        <div class="photo-item">
            <div class="photo-placeholder"><span>Photo 4</span></div>
            <p class="photo-caption">My workspace setup</p>
        </div>
        <div class="photo-item">
            <div class="photo-placeholder"><span>Photo 5</span></div>
            <p class="photo-caption">Weekend road trip</p>
        </div>
        <div class="photo-item">
            <div class="photo-placeholder"><span>Photo 6</span></div>
            <p class="photo-caption">Winter snow scene</p>
        </div>
    </div>

    <p style="margin-top: 15px; font-size: 11px; color: #808080">
