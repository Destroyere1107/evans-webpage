    Layout = "_CalculatorLayout";
    ViewData["Title"] = "[Calculator Name] - Destroyere1107's Calculator Museum";
}

@section PageSidebar {
    <!-- TEMPLATE: Add page-specific sidebar content here (e.g. external links) -->
