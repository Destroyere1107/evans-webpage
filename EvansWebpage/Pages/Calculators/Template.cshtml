            <th style="padding: 4px 8px; text-align: left; border: 1px solid #999999;">Serial Number</th>
            <th style="padding: 4px 8px; text-align: left; border: 1px solid #999999;">Condition</th>
            <th style="padding: 4px 8px; text-align: left; border: 1px solid #999999;">Pictures</th>
        </tr>
        <tr>
            <td style="padding: 4px 8px; border: 1px solid #999999; text-align: center;">1</td>
            <td style="padding: 4px 8px; border: 1px solid #999999">[Insert variant]</td>
            <td style="padding: 4px 8px; border: 1px solid #999999">[Insert SN]</td>
            <td style="padding: 4px 8px; border: 1px solid #999999">[Insert condition]</td>
            <td style="padding: 4px 8px; border: 1px solid #999999">
                <!-- TEMPLATE: Insert img tags here -->
                [Insert picture(s)]
            </td>
        </tr>
        <!-- TEMPLATE: Duplicate the row above for additional specimens -->
    </table>
    <h3 style="margin-top: 0">About these specimen(s)</h3>
