{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Calculator Exhibit Library",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "manufacturer", "model"],
    "properties": {
      "id": {
        "type": "string",
        "description": "The URL-friendly identifier for the page route, e.g. 50g"
      },
      "name": {
        "type": "string",
        "description": "The full display name, e.g. Hewlett-Packard 50g"
      },
      "manufacturer": {
        "type": "string",
        "enum": ["Hewlett-Packard", "Casio", "Texas Instruments", "Other"],
        "description": "Manufacturer of the calculator."
      },
      "manufacturerLogo": {
        "type": "string",
        "default": "~/assets/logos/hp-logo.png",
        "description": "Path to the logo image file."
      },
      "model": {
        "type": "string"
      },
      "yearIntroduced": {
        "type": "integer"
      },
      "type": {
        "type": "string",
        "enum": ["Graphing Calculator (CAS)", "Graphing Calculator", "Scientific Calculator", "Financial Calculator", "Four-Function Calculator"],
        "description": "The category of the calculator."
      },
      "myCalcsSearchId": {
        "type": "string",
        "description": "The numeric ID used in the MyCalcs URL, e.g. 74 for the HP 50g"
      },
      "historyHtml": {
        "type": "string",
        "description": "The HTML-formatted paragraphs detailing the history and background of the model."
      },
      "specimens": {
        "type": "array",
        "description": "The specific specimens in the collection.",
        "items": {
          "type": "object",
          "required": ["number", "variant", "serialNumber"],
          "properties": {
            "number": { "type": "integer" },
            "variant": { "type": "string", "default": "Normal" },
            "serialNumber": { "type": "string" },
            "condition": { "type": "string", "enum": ["Mint", "Good", "Fair", "Poor", "Broken"] },
            "imageUrl": { "type": "string", "description": "URL to the hosted image of this specimen." },
            "notes": { "type": "string" }
          }
        }
      }
    }
  }
}