{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Calculator Exhibit Library",
  "type": "array",
  "items": {
    "properties": {
      "id": {
        "type": "string",
        "description": "The URL-friendly identifier for the page route, e.g. 50g"
      },
      "name": {
        "type": "string",
        "description": "The full display name, e.g. Hewlett-Packard 50g"
      },
      "category": {
        "type": "string",
        "enum": [
          "Calculator",
          "Accessory",
          "Other"
        ],
        "description": "The broad classification of the exhibit, used for organizing in the directory."
      },
      "manufacturer": {
        "type": "string",
        "enum": [
          "Hewlett-Packard",
          "Casio",
          "Texas Instruments",
          "Other"
        ],
        "description": "Manufacturer of the calculator."
      },
      "manufacturerLogo": {
        "type": "string",
        "default": "~/assets/logos/hp-logo.png",
        "description": "Path to the logo image file."
      },
      "model": {
        "type": "string",
        "description": "The shortened model name, e.g. HP 50g"
      },
      "yearIntroduced": {
        "type": "integer"
      },
      "type": {
        "type": "string",
        "enum": [
          "Graphing Calculator (CAS)",
          "Graphing Calculator",
          "Scientific Calculator",
          "Financial Calculator",
          "Financial Calculator (Printing)",
          "Four-Function Calculator"
        ],
        "description": "The category of the calculator."
      },
      "myCalcsSearchIds": {
        "type": "array",
        "description": "An array of numeric IDs used in the MyCalcs URLs.",
        "items": {
          "type": "string"
        }
      },
      "specimens": {
        "type": "array",
        "description": "The specific specimens in the collection.",
        "items": {
          "type": "object",
          "required": [
            "number",
            "variant",
            "serialNumber"
          ],
          "properties": {
            "number": {
              "type": "integer"
            },
            "variant": {
              "type": "string",
              "default": "Normal"
            },
            "serialNumber": {
              "type": "string"
            },
            "condition": {
              "type": "string",
              "enum": [
                "Mint",
                "Good",
                "Fair",
                "Poor",
                "Broken"
              ]
            },
            "imageUrl": {
              "type": "string",
              "description": "URL to the hosted image of this specimen."
            }
          }
        }
      },
      "gallery": {
        "type": "array",
        "description": "Additional photos for the gallery section.",
        "items": {
          "type": "object",
          "required": ["url", "altText"],
          "properties": {
            "url": {
              "type": "string",
              "description": "URL of the image."
            },
            "altText": {
              "type": "string",
              "description": "Accessibility text for screen readers."
            },
            "caption": {
              "type": "string",
              "description": "Optional caption to display underneath the image."
            }
          }
        }
      },
      "manufacturerSlug": {
        "type": "string",
        "enum": ["hp", "casio", "ti", "other"],
        "description": "The slug used for internally identifying the manufacturer"
      },
      "modelSlug": {
        "type": "string",
        "description": "The slug used for internally identifying the model"
      },
      "mainImageUrl": {
        "type": "string",
        "description": "URL to the main feature image displayed above the Quick Facts table."
      },
      "underConstruction": {
        "type": "boolean",
        "description": "Determines whether the the 'Coming Soon' tag and 'Under Construction' banner are displayed.",
        "default": false
      }
    },
    "required": [
      "id",
      "name",
      "manufacturer",
      "model",
      "type",
      "manufacturerSlug",
      "modelSlug",
      "category"
    ],
    "type": "object"
  }
}